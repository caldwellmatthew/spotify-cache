{
  "name": "scrubbler",
  "version": "1.0.0",
  "description": "Scrobbles and sanitizes your Spotify listening history to Last.fm",
  "main": "dist/server/index.js",
  "scripts": {
    "dev:server": "ts-node-dev --respawn --transpile-only src/server/index.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker/index.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "build:server": "tsc",
    "build:client": "vite build",
    "start:server": "NODE_ENV=production node dist/server/index.js",
    "start:worker": "node dist/worker/index.js",
    "migrate": "cat migrations/*.sql | psql $DATABASE_URL",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.client.json"
  },
  "dependencies": {
    "@types/cookie-parser": "^1.4.10",
    "axios": "^1.6.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.3",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
"preact": "^10.28.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  }
}
